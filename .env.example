VITE_GA_MEASUREMENT_ID=G-ZERSFR2192

# Painel do blog (Basic Auth em blog.servicostech.com.br/admin).
# Defina no .env de cada ambiente — NUNCA versione a senha real.
BLOG_ADMIN_USER=admin
BLOG_ADMIN_PASS=troque-por-uma-senha-forte
# Caminho secreto do painel (opcional; padrao /admin):
# BLOG_ADMIN_PATH=/admin5468

# Opcionais (tem padrao no codigo):
# BLOG_HOST=blog.servicostech.com.br
# WEBSCRAPER_HOST=127.0.0.1
# WEBSCRAPER_PORT=5000

# --- Alertas de seguranca + GeoIP (ops/logs/, rodados por cron) ---
# Canais de alerta (qualquer combinacao):
# ALERT_WHATSAPP_PHONE=5511915155349
# ALERT_WHATSAPP_APIKEY=                 # chave do CallMeBot
# ALERT_WEBHOOK_URL=                     # Discord/Slack/Telegram/n8n/Make
# ALERT_EMAIL_TO=voce@dominio.com        # usa o sendmail do sistema
# Limiares do alerta de forca-bruta (opcionais):
# ALERT_401_THRESHOLD=5
# ALERT_401_WINDOW_MIN=15
# ALERT_COOLDOWN_MIN=60
# GeoIP local MaxMind (opcional; sem isso usa o ip-api.com):
# GEOIP_MMDB=/var/www/servicostech.com.br/ops/geo/GeoLite2-City.mmdb
